# Optional systemd environment overrides for Sis.
#
# Copy this file to /etc/sis/sis.env and uncomment the values that should
# override /etc/sis/sis.yaml for a production service.

# Listen on the standard DNS port. The systemd unit grants CAP_NET_BIND_SERVICE.
# SIS_DNS_LISTEN=0.0.0.0:53,[::]:53

# Keep the WebUI/API on localhost when a reverse proxy terminates TLS.
# Use 0.0.0.0:8080 only on a trusted management network or behind a firewall.
# SIS_HTTP_LISTEN=127.0.0.1:8080

# Persist runtime state, logs, sessions, policy cache, stats, and debug dumps.
# SIS_DATA_DIR=/var/lib/sis

# Privacy-oriented query logging. Use "hashed" or "anonymous" for production.
# SIS_PRIVACY_LOG_MODE=hashed
# SIS_PRIVACY_LOG_SALT=

# DNS ingress protection.
# SIS_DNS_RATE_LIMIT_QPS=200
# SIS_DNS_RATE_LIMIT_BURST=400

# Session lifetime for the WebUI/API cookie.
# SIS_AUTH_SESSION_TTL=24h
